[
  {
    "id": "TC001",
    "title": "Switch to Register tab shows registration form",
    "description": "Verifies the user can toggle from Login to Register and see the registration UI.",
    "category": "User Authentication",
    "priority": "Medium",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /auth"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Login\" is visible"
      },
      {
        "type": "action",
        "description": "Click on \"Register\" tab"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Register\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Email\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Password\" is visible"
      }
    ]
  },
