  {
    "id": "TC004",
    "title": "Register with invalid email format shows validation error",
    "description": "Verifies the registration form rejects an invalid email format and does not redirect.",
    "category": "User Authentication",
    "priority": "Medium",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /auth"
      },
      {
        "type": "action",
        "description": "Click on \"Register\" tab"
      },
      {
        "type": "action",
        "description": "Type \"not-an-email\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"ValidPass!23456\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the submit button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/auth\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"Email\" is visible"
      }
    ]
  },
  {
    "id": "TC005",
    "title": "Create analysis, calculate profit/risk, and save to reach detailed analysis view",
    "description": "Verifies a user can create a new product profit analysis, calculate results, save it, and land on the detailed analysis page.",
    "category": "Product Profit Analysis",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /auth"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" or \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click the \"New Analysis\" or \"New\" button/link to open the new product analysis form"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/analysis/new"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Calculate\" is visible"
      }
    ]
  },
  {
    "id": "TC006",
    "title": "Save after calculation redirects to detailed analysis page",
    "description": "Verifies saving a calculated analysis redirects from the form to a detailed analysis view URL.",
    "category": "Product Profit Analysis",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /auth"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" or \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click the \"New Analysis\" or \"New\" button/link to open the new product analysis form"
      },
      {
        "type": "action",
        "description": "Select \"Trendyol\" from the marketplace dropdown"
      },
      {
        "type": "action",
        "description": "Type \"200\" into the product cost field"
      },
      {
        "type": "action",
        "description": "Type \"275\" into the sale price field"
      },
      {
        "type": "action",
        "description": "Type \"15\" into the shipping cost field"
      },
      {
        "type": "action",
        "description": "Click the \"Calculate\" button"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/analysis/\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Detailed\" is visible"
      }
    ]
  },
