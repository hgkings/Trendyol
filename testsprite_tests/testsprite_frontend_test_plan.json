[
  {
    "id": "TC001",
    "title": "Create profit analysis with all fields completed",
    "description": "Verifies a user can calculate and view profit analysis results when all required inputs are provided.",
    "category": "Create Profit Analysis",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on the \"New Analysis\" or \"Create Analysis\" navigation option"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/analysis/new\""
      },
      {
        "type": "action",
        "description": "Select a marketplace option from the Marketplace dropdown"
      },
      {
        "type": "action",
        "description": "Type \"Test Product\" into the Product Name field"
      },
      {
        "type": "action",
        "description": "Type \"100\" into the Price field"
      },
      {
        "type": "action",
        "description": "Type \"60\" into the Cost field"
      },
      {
        "type": "action",
        "description": "Type \"10\" into the Commission field"
      },
      {
        "type": "action",
        "description": "Click the \"Calculate\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Margin\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Fees\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Analysis Results\" is visible"
      }
    ]
  },
